{
  "name": "eventlens",
  "version": "1.0.0",
  "description": "Full-stack EventLens event discovery SPA for Project 3.",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "start": "node server/index.js",
    "seed": "node server/src/seed.js",
    "client": "vite --host 0.0.0.0 --config client/vite.config.mjs",
    "build": "vite build --config client/vite.config.mjs",
    "preview": "vite preview --config client/vite.config.mjs",
    "test": "node --test server/tests"
  },
  "keywords": [
    "react",
    "express",
    "mongodb",
    "pwa",
    "events"
  ],
  "author": "Sravani Medaga",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bootstrap": "^5.3.3",
    "compression": "^1.7.4",
    "connect-mongo": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "mongoose": "^8.3.2",
    "morgan": "^1.10.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "sass": "^1.75.0",
    "vite": "^6.4.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
